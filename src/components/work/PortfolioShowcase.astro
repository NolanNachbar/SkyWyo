---
interface Film {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  location: string;
  architect: string;
  listing: string;
  conversion: string;
  imageUrl: string;
  isWide?: boolean;
}

const films: Film[] = [
  {
    id: '01',
    title: 'Bar S Reserve',
    subtitle: 'River',
    description: 'Photographed across two consecutive first lights and a single dawn pass over the cottonwoods. We tracked the morning mist for forty-eight hours to capture the exact moment the light breaks across the Snake River oxbow.',
    location: 'Jackson Hole, WY',
    architect: 'Carney Logan Burke',
    listing: '$48.5M',
    conversion: '14 days',
    imageUrl: 'https://images.unsplash.com/photo-1518780664697-55e3ad937233?auto=format&fit=crop&w=2200&q=85',
    isWide: true
  },
  {
    id: '02',
    title: 'Lone Cottonwood',
    subtitle: 'Alpine',
    description: 'Captured during the first heavy snow of October. A study in architectural contrast: heavy timber against the soft, high-altitude grain of a Teton blizzard. Delivered as a seasonal counterpart to our summer production.',
    location: 'Teton Village, WY',
    architect: 'JLF Architects',
    listing: '$36.0M',
    conversion: 'N/A',
    imageUrl: 'https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&w=2200&q=85'
  },
  {
    id: '03',
    title: 'Silver Sage Ranch',
    subtitle: 'Working ranch',
    description: 'A 14,200-acre working ranch captured during the evening gather. One orbit at last light, holding a single shot for thirty-eight seconds to respect the scale of the movement and the silence of the Bighorn foothills.',
    location: 'Big Horn, WY',
    architect: 'Pearson Design Group',
    listing: '$72.0M',
    conversion: 'Off-market',
    imageUrl: 'https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?auto=format&fit=crop&w=2200&q=85'
  },
  {
    id: '04',
    title: 'The Wind River House',
    subtitle: 'River pavilion',
    description: 'Filmed entirely in available light over a single eighteen-hour summer day. A study of transparency and reflection, tracking the Green River\'s movement across the glass-and-corten pavilion from dawn to blue hour.',
    location: 'Pinedale, WY',
    architect: 'Stephen Dynia',
    listing: '$22.4M',
    conversion: '31 days',
    imageUrl: 'https://images.unsplash.com/photo-1444723121867-7a241cacace9?auto=format&fit=crop&w=2200&q=85',
    isWide: true
  }
];
---

<section id="work" class="page-px py-30 md:py-40 border-t border-rule">
  <div class="max-w-[1400px] mx-auto mb-20 md:mb-[80px] flex flex-col md:flex-row justify-between items-start md:items-end gap-15 md:gap-[60px]">
    <h2 class="serif text-[clamp(40px,5.4vw,92px)] leading-[1.02] tracking-[-0.022em] max-w-[14ch] reveal">
      Selected <em class="italic text-[#d6c89f]">productions.</em>
    </h2>
    <p class="max-w-[38ch] text-paper-dim text-[var(--text-sm)] leading-relaxed reveal delay-75">
      Atmospheric studies of land, commercial assets, and residential estates. Each production is authored around the unique light and weather patterns of the property.
    </p>
  </div>

  <div class="max-w-[1400px] mx-auto flex flex-col gap-35 md:gap-[140px]">
    {films.map((film, index) => (
      <article class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-[48px] items-end reveal">
        <div class={`relative overflow-hidden bg-[#1a1916] group ${film.isWide ? 'aspect-[16/10]' : 'aspect-[4/5]'} ${index % 2 !== 0 ? 'md:order-2' : 'md:order-1'}`}>
          <div 
            class="absolute inset-0 bg-cover bg-center scale-104 group-hover:scale-108 transition-transform duration-[1400ms] ease-soft cinematic-grade"
            style={`background-image: url('${film.imageUrl}')`}
          />
          <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/55 pointer-events-none" />
          <div class="absolute top-6 left-6 text-[var(--text-xs)] tracking-plate uppercase text-white/80 bg-black/35 backdrop-blur-md px-3 py-2 border border-white/18">
            Production № {film.id} · {film.subtitle}
          </div>
        </div>

        <div class={`pb-3.5 ${index % 2 !== 0 ? 'md:order-1' : 'md:order-2'}`}>
          <span class="serif italic text-[var(--text-lg)] text-paper-mute mb-3.5 block">N° {film.id} — MMXXV</span>
          <h3 class="serif text-[clamp(34px,3.6vw,58px)] leading-[1.02] tracking-[-0.02em] mb-4.5">
            {film.title.split(' ').map((word, i, arr) => i === arr.length - 1 ? <em class="italic text-[#d6c89f]">{word}</em> : word + ' ')}
          </h3>
          <p class="text-[var(--text-base)] leading-relaxed text-paper-2 max-w-[38ch] mb-0">
            {film.description}
          </p>
          
          <div class="flex flex-wrap gap-12 border-t border-rule pt-4.5 mt-6 text-[var(--text-sm)] tracking-nav uppercase text-paper-dim">
            <div>
              <b class="block text-paper font-medium mb-1 tracking-tight">Location</b>
              {film.location}
            </div>
            <div>
              <b class="block text-paper font-medium mb-1 tracking-tight">Scope</b>
              {film.architect}
            </div>
            <div>
              <b class="block text-paper font-medium mb-1 tracking-tight">Market</b>
              {film.listing}
            </div>
            {film.conversion !== 'N/A' && (
              <div>
                <b class="block text-paper font-medium mb-1 tracking-tight">Status</b>
                {film.conversion}
              </div>
            )}
          </div>

          <a href="#" class="group mt-7.5 inline-flex items-center gap-3.5 text-[var(--text-sm)] tracking-plate uppercase text-paper pb-1.5 border-b border-rule-strong hover:gap-5.5 hover:border-paper transition-all duration-350 ease-soft">
            View the film
            <svg class="w-3.5 h-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
</style>
