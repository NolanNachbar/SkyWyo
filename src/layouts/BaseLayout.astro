---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "SkyWyo — Drone photo & video for Wyoming luxury listings",
	description = "Drone photo & video for Cheyenne and Laramie's luxury listings. Edited, MLS-ready, back in 48 hours. FAA Part 107 certified, Wyoming owned & operated. Your first shoot is free."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://skywyo.com/og-image.jpg" />
		<meta property="og:url" content="https://skywyo.com" />
		<meta property="og:site_name" content="SkyWyo" />
		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://skywyo.com/og-image.jpg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
	</head>
	<body>
		<slot />
	</body>
</html>
