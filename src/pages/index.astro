---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrubHero from '../components/hero/ScrubHero';
import BookForm from '../components/book/BookForm';

// FAQ content — rendered on the page AND mirrored into FAQPage schema below.
// Google requires the schema text to match the visible page text.
const faqs = [
  {
    q: "How much does drone real estate photography cost in Cheyenne and Laramie?",
    a: "Your first shoot is free. After that, a standard package is $349 and includes an edited aerial photo set plus a 60-second branded listing video, delivered in 48 hours. Larger listings and add-ons are quoted on top.",
  },
  {
    q: "How fast will I get the photos and video?",
    a: "48 hours from the shoot to your inbox, edited and MLS-ready, so the listing goes live with the footage instead of weeks later.",
  },
  {
    q: "Are you FAA certified?",
    a: "Yes. SkyWyo is an FAA Part 107 certified commercial drone operation, flying an FAA-registered aircraft within federal airspace rules.",
  },
  {
    q: "Do you only shoot land and acreage?",
    a: "We shoot every kind of listing: homes in town, vacant lots, acreage, and large ranches. Aerial captures the whole property, the setting, and the approach that ground-level photos leave out, which is what buyers want to see before they ever drive out.",
  },
  {
    q: "What areas of Wyoming do you serve?",
    a: "We are based in Cheyenne and Laramie and serve real estate listings across the whole state of Wyoming.",
  },
  {
    q: "Do I have to sign a contract or pay anything upfront?",
    a: "No. The first shoot is free, with no contract and no deposit. You decide whether to keep working with us after you see the footage.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://skywyo.com/#business",
      "name": "SkyWyo",
      "description": "Drone photo and video for Wyoming real estate listings. Based in Cheyenne and Laramie, serving the whole state. Edited, MLS-ready in 48 hours. FAA Part 107 certified. First shoot free.",
      "url": "https://skywyo.com",
      "image": "https://skywyo.com/og-image.jpg",
      "email": "info@skywyo.com",
      "priceRange": "$$",
      "foundingDate": "2026",
      // sameAs: add Google Business Profile, Instagram, Facebook, YouTube URLs once those exist.
      "areaServed": [
        { "@type": "State", "name": "Wyoming" },
        { "@type": "City", "name": "Cheyenne" },
        { "@type": "City", "name": "Laramie" }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Cheyenne",
        "addressRegion": "WY",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 41.1400,
        "longitude": -104.8202
      },
      "makesOffer": {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Aerial real estate photo and video",
          "description": "Edited aerial photo set and a 60-second branded listing video, delivered in 48 hours. First shoot free."
        }
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://skywyo.com/#faq",
      "mainEntity": faqs.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    }
  ]
};

// Portfolio stills — clear drone frames from our own footage.
const workShots = [
  { src: '/hero/frames/frame_0006.jpg', alt: 'Aerial drone still over a Wyoming property' },
  { src: '/hero/frames/frame_0064.jpg', alt: 'Aerial drone still of Wyoming acreage' },
  { src: '/hero/frames/frame_0112.jpg', alt: 'Aerial drone still of a Wyoming listing at altitude' },
];
---

<BaseLayout>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div id="top">
    <ScrubHero
      client:load
      headline="The whole listing from the air."
      sub="We shoot your first listing free, anywhere in Wyoming, and you keep the footage even if you never call again. Edited and MLS-ready in 48 hours."
    />

    <!-- The problem -->
    <section class="pain" id="problem">
      <div class="wrap">
        <span class="eyebrow reveal">The problem</span>
        <h2 class="reveal">From the ground, every listing looks the same.</h2>
        <div class="cols">
          <p class="lead reveal">
            Ground-level photos show the same few angles every other listing shows. They
            leave out what makes a property worth the drive: the land and the views on
            acreage, the setting and the layout in town. Aerial shows a buyer the whole
            property before they ever pull into the driveway.
          </p>
          <div class="enemy reveal">
            Phone photos make your listing look like every other one.
            <small>Buyers slow down on aerial. One frame shows the whole property in context, which a ground-level photo can't.</small>
          </div>
        </div>
      </div>
    </section>

    <!-- What you get -->
    <section class="deliver" id="deliverables">
      <div class="wrap">
        <span class="eyebrow reveal">What you get</span>
        <h2 class="reveal">Three deliverables, named and priced. Nothing to decode.</h2>
        <div class="grid">
          <div class="card reveal">
            <div class="num">01</div>
            <h3>Edited aerial photo set</h3>
            <p>High-resolution stills of the house, the acreage, and the approach. Color-corrected and sized for MLS and web. Yours to keep.</p>
          </div>
          <div class="card reveal">
            <div class="num">02</div>
            <h3>A 60-second listing video</h3>
            <p>One branded cut for MLS, YouTube, and social, with your name and brokerage on the end card.</p>
          </div>
          <div class="card reveal">
            <div class="num">03</div>
            <h3>48-hour turnaround</h3>
            <p>Shoot one day, footage in your inbox the next. The listing goes live with the video the same week it hits the market.</p>
          </div>
        </div>
        <p class="lead reveal" style="text-align: center; max-width: 60ch; margin: 40px auto 0;">All three together is one Sky Pro shoot, $349. Your first shoot is free, and larger acreage or luxury listings are quoted on request.</p>
      </div>
    </section>

    <!-- Recent work -->
    <section class="work" id="work">
      <div class="wrap">
        <span class="eyebrow reveal">Our footage</span>
        <h2 class="reveal">The footage speaks for itself.</h2>
        <div class="slot-grid">
          {workShots.map((shot) => (
            <div class="shot reveal">
              <img src={shot.src} alt={shot.alt} loading="lazy" width="1920" height="1080" />
            </div>
          ))}
        </div>
        <p class="slot-note reveal">Every frame here is real SkyWyo footage shot over Wyoming. No stock, no rentals. Your property is next.</p>
      </div>
    </section>

    <!-- The math -->
    <section class="math" id="math">
      <div class="wrap">
        <div style="text-align: center;">
          <span class="eyebrow reveal">The math</span>
          <h2 class="reveal" style="max-width: 24ch; margin: 0 auto;">Media costs a fraction of your commission.</h2>
          <p class="lead reveal" style="max-width: 60ch; margin: 20px auto 0;">A Sky Pro shoot is $349. One closing is thousands in commission, at any price point, so good listing media pays for itself many times over on a single sale.</p>
        </div>
        <p class="kicker reveal">Stronger listing media helps a property draw more interest and sell sooner, so you earn your commission faster. And the first shoot is free.</p>
      </div>
    </section>

    <!-- The promise -->
    <section class="promise" id="promise">
      <div class="wrap">
        <span class="eyebrow reveal" style="color: #9cc1dc;">The promise</span>
        <h2 class="reveal">Your first shoot is <em>free.</em></h2>
        <p class="lead reveal">You have never seen our work on one of your listings, so we are not asking you to trust it sight unseen. SkyWyo flies the property, edits it, and sends it over. If it doesn't make the listing look more expensive than the ground photos did, you keep the footage and we're done. No contract, no deposit, no card. The only thing you risk is an hour of access.</p>
        <a class="btn btn--lg btn--on-dark reveal" href="#book">Book your free first shoot</a>
        <div class="chips reveal">
          <span class="chip">No contract</span>
          <span class="chip">No deposit</span>
          <span class="chip">You keep the footage either way</span>
        </div>
      </div>
    </section>

    <!-- Credibility -->
    <section class="cred" id="credibility">
      <div class="wrap">
        <span class="eyebrow reveal">Why trust the flight</span>
        <h2 class="reveal">Licensed, local, legal.</h2>
        <div class="grid">
          <div class="fact reveal">
            <h3>FAA Part 107 certified</h3>
            <p>The commercial license the FAA requires to fly a paid real-estate shoot. Legal to put the footage on a listing.</p>
          </div>
          <div class="fact reveal">
            <h3>FAA-registered aircraft</h3>
            <p>Flown inside federal airspace rules, so nothing about the shoot puts your listing at risk.</p>
          </div>
          <div class="fact reveal">
            <h3>Cheyenne and Laramie based</h3>
            <p>A local crew you can call, not an out-of-state aggregator reselling a stranger's flight time.</p>
          </div>
        </div>
        <div class="testimonial-slot reveal">
          <strong>Agent testimonials will live here.</strong>
          Reserved until the first clients have footage in hand. Nothing on this page is invented.
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq" id="faq">
      <div class="wrap">
        <span class="eyebrow reveal">Questions</span>
        <h2 class="reveal">Drone real estate photography in Cheyenne and Laramie</h2>
        <div class="faq-list">
          {faqs.map((f) => (
            <div class="faq-item reveal">
              <h3>{f.q}</h3>
              <p>{f.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Booking -->
    <section class="book" id="book">
      <div class="wrap">
        <div class="inner">
          <span class="eyebrow reveal">Get started</span>
          <h2 class="reveal">Book your free first shoot.</h2>
          <p class="lead reveal" style="margin: 0 auto;">Send us the listing address. We confirm a flight window within one business day.</p>
          <div class="reveal">
            <BookForm client:visible />
          </div>
        </div>
      </div>
    </section>

    <footer>
      <div class="wrap">
        <div class="row">
          <span class="logo">SKYWYO</span>
          <div class="meta">
            <span>Based in Cheyenne &amp; Laramie · Serving all of Wyoming</span>
            <span>FAA Part 107 Certified</span>
          </div>
          <span class="contact">
            <a href="mailto:info@skywyo.com">info@skywyo.com</a>
          </span>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('reveal-in');
        io.unobserve(entry.target);
      }
    });
  }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });

  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>

<style>
  .faq-list {
    margin-top: 44px;
    max-width: 820px;
  }
  .faq-item {
    padding: 26px 0;
    border-top: 1px solid var(--line, #e6e2d9);
  }
  .faq-item:last-child {
    border-bottom: 1px solid var(--line, #e6e2d9);
  }
  .faq-item h3 {
    margin: 0 0 8px;
    font-size: 19px;
    font-weight: 700;
    line-height: 1.3;
  }
  .faq-item p {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--body, #3f4750);
    max-width: 70ch;
  }
</style>
