---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrubHero from '../components/hero/ScrubHero';
import BookForm from '../components/book/BookForm';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "SkyWyo",
  "description": "Drone photo and video for Cheyenne and Laramie's luxury real estate listings. Edited, MLS-ready, back in 48 hours. FAA Part 107 certified, Wyoming owned and operated.",
  "url": "https://skywyo.com",
  "areaServed": [
    { "@type": "City", "name": "Cheyenne" },
    { "@type": "City", "name": "Laramie" },
    { "@type": "State", "name": "Wyoming" }
  ],
  "address": {
    "@type": "PostalAddress",
    "addressRegion": "WY",
    "addressCountry": "US"
  },
  "makesOffer": {
    "@type": "Offer",
    "itemOffered": {
      "@type": "Service",
      "name": "Aerial real estate photo & video",
      "description": "Edited aerial photo set and a 60-second branded listing video, delivered in 48 hours. First shoot free."
    }
  }
};

// Portfolio stills — clear drone frames from our own footage.
const workShots = [
  { src: '/hero/frames/frame_0006.jpg', alt: 'Aerial drone still over a Wyoming property' },
  { src: '/hero/frames/frame_0064.jpg', alt: 'Aerial drone still of Wyoming acreage' },
  { src: '/hero/frames/frame_0112.jpg', alt: 'Aerial drone still of a Wyoming listing at altitude' },
];
---

<BaseLayout>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div id="top">
    <ScrubHero
      client:load
      headline="Sell the land, not just the house."
      sub="Drone photo & video for Cheyenne and Laramie's luxury listings — edited, MLS-ready, back in 48 hours."
    />

    <!-- The problem -->
    <section class="pain" id="problem">
      <div class="wrap">
        <span class="eyebrow reveal">The problem</span>
        <h2 class="reveal">Your $700K listing is being shot like a starter home.</h2>
        <div class="cols">
          <p class="lead reveal">
            Out here, the asset is the land — the acreage, the views, the distance to the
            nearest neighbor. Ground-level photos can't show any of it. So buyers scroll
            past a property worth driving to, because from the driveway it looks like
            every other house.
          </p>
          <div class="enemy reveal">
            Phone photos price your listing down.
            <small>The same buyers who skip past them stop on aerial footage — because almost no listing in the county has it.</small>
          </div>
        </div>
      </div>
    </section>

    <!-- What you get -->
    <section class="deliver" id="deliverables">
      <div class="wrap">
        <span class="eyebrow reveal">What you get</span>
        <h2 class="reveal">Concrete deliverables. No packages to decode.</h2>
        <div class="grid">
          <div class="card reveal">
            <div class="num">01</div>
            <h3>Edited aerial photo set</h3>
            <p>High-resolution stills of the property, the acreage, and the approach — color-corrected, MLS- and web-sized.</p>
          </div>
          <div class="card reveal">
            <div class="num">02</div>
            <h3>A 60-second listing video</h3>
            <p>One branded cut, ready for MLS, YouTube, and social — with your name and brokerage on the end card.</p>
          </div>
          <div class="card reveal">
            <div class="num">03</div>
            <h3>Back in 48 hours</h3>
            <p>Shoot to inbox in two days. Your listing goes live with the footage, not two weeks after the price cut.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Recent work -->
    <section class="work" id="work">
      <div class="wrap">
        <span class="eyebrow reveal">Recent work</span>
        <h2 class="reveal">The footage speaks for itself.</h2>
        <div class="slot-grid">
          {workShots.map((shot) => (
            <div class="shot reveal">
              <img src={shot.src} alt={shot.alt} loading="lazy" width="1920" height="1080" />
            </div>
          ))}
        </div>
        <p class="slot-note reveal">Frames pulled straight from the hero flight above — real footage, no stock. Your listing's stills slot in right here after the first shoot.</p>
      </div>
    </section>

    <!-- The math -->
    <section class="math" id="math">
      <div class="wrap">
        <div style="text-align: center;">
          <span class="eyebrow reveal">The math</span>
          <h2 class="reveal" style="max-width: 20ch; margin: 0 auto 0;">One closing pays for years of media.</h2>
        </div>
        <div class="eq reveal" role="img" aria-label="$700,000 listing times 2.5% commission equals $17,500 to you">
          <div class="term"><div class="v">$700,000</div><div class="k">Your listing</div></div>
          <div class="op">×</div>
          <div class="term"><div class="v">2.5%</div><div class="k">Your side</div></div>
          <div class="op">=</div>
          <div class="term result"><div class="v">$17,500</div><div class="k">Your commission</div></div>
        </div>
        <p class="kicker reveal">The footage that helps it sell costs you nothing to try — the first shoot is free.</p>
      </div>
    </section>

    <!-- The promise -->
    <section class="promise" id="promise">
      <div class="wrap">
        <span class="eyebrow reveal" style="color: #9cc1dc;">The promise</span>
        <h2 class="reveal">Your first shoot is <em>free.</em></h2>
        <p class="lead reveal">You only keep working with me if you love the footage. No contract, no deposit, no risk — if it doesn't make your listing look more expensive, you've lost nothing but an hour.</p>
        <a class="btn btn--lg btn--on-dark reveal" href="#book">Book your free first shoot</a>
        <div class="chips reveal">
          <span class="chip">No contract</span>
          <span class="chip">No deposit</span>
          <span class="chip">Keep the footage decision yours</span>
        </div>
      </div>
    </section>

    <!-- Credibility -->
    <section class="cred" id="credibility">
      <div class="wrap">
        <span class="eyebrow reveal">Why trust the flight</span>
        <h2 class="reveal">Licensed, local, legal.</h2>
        <div class="grid">
          <div class="fact reveal">
            <h3>FAA Part 107 certified</h3>
            <p>A licensed commercial drone pilot — the certification the FAA requires for paid real-estate flights.</p>
          </div>
          <div class="fact reveal">
            <h3>Registered aircraft</h3>
            <p>Flying an FAA-registered drone, operated within federal airspace rules.</p>
          </div>
          <div class="fact reveal">
            <h3>Wyoming owned &amp; operated</h3>
            <p>Based in Cheyenne and Laramie — not an out-of-state aggregator reselling a stranger's time.</p>
          </div>
        </div>
        <div class="testimonial-slot reveal">
          <strong>Agent testimonials will live here.</strong>
          Reserved until the first clients have footage in hand — nothing on this page is invented.
        </div>
      </div>
    </section>

    <!-- Booking -->
    <section class="book" id="book">
      <div class="wrap">
        <div class="inner">
          <span class="eyebrow reveal">Get started</span>
          <h2 class="reveal">Book your free first shoot.</h2>
          <p class="lead reveal" style="margin: 0 auto;">Tell me where the listing is. I'll confirm a flight window within one business day.</p>
          <div class="reveal">
            <BookForm client:visible />
          </div>
        </div>
      </div>
    </section>

    <footer>
      <div class="wrap">
        <div class="row">
          <span class="logo">SKYWYO</span>
          <div class="meta">
            <span>Cheyenne &amp; Laramie, Wyoming</span>
            <span>FAA Part 107 Certified</span>
          </div>
          <span class="contact">
            <a href="mailto:nolan@dewittdroneservices.com">nolan@dewittdroneservices.com</a>
          </span>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  const io = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('reveal-in');
        io.unobserve(entry.target);
      }
    });
  }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });

  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
