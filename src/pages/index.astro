---
import BaseLayout from '../layouts/BaseLayout.astro';
import CanvasHero from '../components/hero/CanvasHero';
import PortfolioShowcase from '../components/work/PortfolioShowcase.astro';
import InquiryForm from '../components/inquiry/InquiryForm';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "SKYWYO",
  "description": "Premium cinematic property storytelling and drone cinematography based in Casper and Laramie, serving all of Wyoming.",
  "url": "https://skywyo.com",
  "telephone": "+1 307 555 0184",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Casper",
    "addressRegion": "WY",
    "postalCode": "82601",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 42.8501,
    "longitude": -106.3252
  },
  "areaServed": {
    "@type": "State",
    "name": "Wyoming"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Drone Cinematography Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Aerial Cinematography",
          "description": "High-altitude 8K drone filming for ranches and estates."
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Architectural Motion Studies",
          "description": "Cinematic ground and gimbal photography for residential and commercial assets."
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What drone cinematography services does SkyWyo offer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SkyWyo offers aerial cinematography up to 8K ProRes RAW, matched ground and gimbal photography on ARRI Alexa Mini LF, director-led editing with principal film, social cut, and showcase loop, and Dolby Vision color grading with print-grade stills."
      }
    },
    {
      "@type": "Question",
      "name": "What areas of Wyoming does SkyWyo serve?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SkyWyo operates statewide from hubs in Casper and Laramie. Primary service areas include Jackson Hole, Teton Village, Big Horn County, Sheridan, Cody, Pinedale, Lander, and Wind River Country."
      }
    },
    {
      "@type": "Question",
      "name": "Is SkyWyo FAA certified?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. All SkyWyo pilots hold FAA Part 107 Remote Pilot Certificates for commercial drone operations. The studio is fully insured and bonded for every production."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a drone cinematography production take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard timeline is 17–30 days: a 7–14 day light and environmental study, a 3-day principal shoot, and a 13–17 day edit and delivery phase. Rush 24–48 hour delivery is available for qualifying projects."
      }
    },
    {
      "@type": "Question",
      "name": "How much does drone cinematography cost in Wyoming?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Each production is scoped individually to the property. SkyWyo does not publish standard pricing. All inquiries receive a response within 24 hours with a production outline and investment range."
      }
    }
  ]
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "SkyWyo",
  "url": "https://skywyo.com",
  "email": "hello@skywyo.com",
  "telephone": "+1 307 555 0184",
  "foundingDate": "2014",
  "areaServed": "Wyoming, USA",
  "description": "Cinematic aerial and ground cinematography studio for ranches, luxury real estate, and commercial properties across Wyoming.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Casper",
    "addressRegion": "WY",
    "postalCode": "82601",
    "addressCountry": "US"
  }
};
---

<BaseLayout>
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
	<CanvasHero client:load />

	<section id="studio" class="page-px py-30 md:py-[200px] md:pb-[220px]">
		<div class="max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-[1fr_2.4fr] gap-20 items-start">
			<aside class="reveal">
				<p class="text-[var(--text-sm)] leading-relaxed text-paper-dim border-t border-rule-strong pt-3.5 mb-4.5">
					A studio of dedicated cinematographers and pilots based in Casper and Laramie. We take on a limited number of productions each month to ensure every property receives our full creative attention.
				</p>
				<div class="flex justify-between gap-4 text-[var(--text-xs)] tracking-plate uppercase text-paper-mute mt-7">
					<span>The Studio</span>
					<span>Wyoming · MMXXVI</span>
				</div>
			</aside>
			<p class="serif text-[var(--text-xl)] md:text-[var(--text-display)] leading-[1.1] tracking-[-0.018em] text-paper reveal delay-75">
				We produce <em class="italic text-[#d6c89f]">cinematic</em> property storytelling that respects the land.<br />
				<span class="text-paper-mute">Slow, deliberate, and designed for scale — at the altitude the West asks to be seen from, in the ninety minutes of light the season agrees to give.</span>
			</p>
		</div>
	</section>

	<section class="border-t border-rule page-px py-30 md:py-[120px]">
		<div class="max-w-[1400px] mx-auto grid grid-cols-2 md:grid-cols-4 gap-12 md:gap-[48px]">
			<div class="reveal">
				<div class="serif text-[clamp(28px,2.5vw,42px)] md:text-[clamp(36px,3vw,56px)] leading-none tracking-[-0.025em] pb-1">
					Certified
				</div>
				<div class="mt-4.5 text-[var(--text-xs)] tracking-plate uppercase text-paper-dim pt-3.5 border-t border-rule max-w-[24ch] leading-relaxed">
					Part 107 certified & fully insured
				</div>
			</div>
			<div class="reveal delay-75">
				<div class="serif text-[clamp(28px,2.5vw,42px)] md:text-[clamp(36px,3vw,56px)] leading-none tracking-[-0.025em] pb-1">
					Statewide
				</div>
				<div class="mt-4.5 text-[var(--text-xs)] tracking-plate uppercase text-paper-dim pt-3.5 border-t border-rule max-w-[24ch] leading-relaxed">
					Based in Casper & Laramie &middot; filming across Wyoming
				</div>
			</div>
			<div class="reveal delay-150">
				<div class="serif text-[clamp(28px,2.5vw,42px)] md:text-[clamp(36px,3vw,56px)] leading-none tracking-[-0.025em] pb-1">
					4K&ndash;8K
				</div>
				<div class="mt-4.5 text-[var(--text-xs)] tracking-plate uppercase text-paper-dim pt-3.5 border-t border-rule max-w-[24ch] leading-relaxed">
					Cinematic aerial and ground delivery
				</div>
			</div>
			<div class="reveal delay-225">
				<div class="serif text-[clamp(28px,2.5vw,42px)] md:text-[clamp(36px,3vw,56px)] leading-none tracking-[-0.025em] pb-1">
					Custom
				</div>
				<div class="mt-4.5 text-[var(--text-xs)] tracking-plate uppercase text-paper-dim pt-3.5 border-t border-rule max-w-[24ch] leading-relaxed">
					Tailored productions for every property scale
				</div>
			</div>
		</div>
	</section>

	<PortfolioShowcase />
	<Testimonials />

	<section id="capabilities" class="page-px py-30 md:py-[200px]">
		<div class="max-w-[1400px] mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-15 md:gap-[60px] items-end mb-22.5 md:mb-[90px]">
				<h2 class="serif text-[var(--text-xl)] md:text-[var(--text-display)] leading-[1.1] tracking-[-0.022em] max-w-[12ch] reveal">
					A complete <em class="italic text-[#d6c89f]">picture.</em>
				</h2>
				<p class="max-w-[40ch] text-paper-dim text-[var(--text-sm)] leading-relaxed reveal delay-75">
					From first ascent to color-graded master. We are pilots, directors, and post-house under one roof — with the cold-weather hours, the wildlife protocols, and the FAA clearances Wyoming demands.
				</p>
			</div>
			
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 border-t border-rule-strong">
				{[
					{
						n: 'i.',
						title: 'Aerial cinematography',
						desc: 'FAA Part 107 pilots cleared for statewide coverage. Inspire 3, Alta X and FPV cinema rigs.',
						items: ['Up to 8K ProRes RAW', 'BLM & ranch coordination', 'Wildlife-aware flight protocols'],
						spec: 'SENSOR 8K · DCI 4096×2160 · PRORES RAW'
					},
					{
						n: 'ii.',
						title: 'Ground & gimbal',
						desc: 'Matched ground photography on Alexa Mini LF and Ronin. One color, one team, one vision for the entire project.',
						items: ['First light to nightscape', 'Winter ops to −20°F', 'Ranch & estate specialists'],
						spec: 'ALEXA MINI LF · COOKE S7/i · RONIN 4D'
					},
					{
						n: 'iii.',
						title: 'Direction & edit',
						desc: 'Story-led edits. A principal film, a social cut, a slow-room loop for the showcase display.',
						items: ['Director on every shoot', 'Three-cut delivery', 'Bespoke score license'],
						spec: 'RESOLVE 19 · DOLBY VISION · H.265 MASTER'
					},
					{
						n: 'iv.',
						title: 'Color & finish',
						desc: 'Dolby Vision masters delivered for every production. High-grade stills included alongside motion.',
						items: ['HDR & SDR delivery', 'Print-grade stills', 'Two rounds of refinement'],
						spec: 'ACES 1.3 · P3 D65 · REC.2020 HDR'
					}
				].map((cap, i) => (
					<div class={`reveal pt-12 pr-8 pb-10 border-b border-rule ${i !== 3 ? 'lg:border-r lg:border-rule' : ''} delay-${i * 75}`}>
						<span class="serif italic text-[var(--text-sm)] text-paper-mute mb-9 block">{cap.n}</span>
						<h4 class="serif text-[var(--text-2xl)] leading-[1.1] tracking-[-0.012em] mb-3.5 text-paper">{cap.title}</h4>
						<p class="text-[var(--text-sm)] leading-relaxed text-paper-dim max-w-[32ch] m-0">{cap.desc}</p>
						<ul class="list-none p-0 mt-4.5 text-[var(--text-sm)] tracking-tight text-paper-mute">
							{cap.items.map(item => (
								<li class="py-1.5 border-t border-rule">{item}</li>
							))}
						</ul>
						<div class="font-mono text-[11px] tracking-[0.14em] text-paper-mute opacity-55 uppercase mt-4 pt-3.5 border-t border-rule">{cap.spec}</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="process" class="page-px py-30 md:py-[200px] bg-gradient-to-b from-[#0a0a0b] to-[#0d0c0a]">
		<div class="max-w-[1280px] mx-auto">
			<div class="mb-16 md:mb-[72px] max-w-[780px]">
				<span class="sans text-[var(--text-xs)] tracking-[0.32em] uppercase text-paper-dim flex items-center gap-3 reveal">
					<span class="w-1.5 h-1.5 rounded-full bg-accent" />
					The Process
				</span>
				<h2 class="serif text-[var(--text-xl)] md:text-[var(--text-display)] leading-[1.1] tracking-[-0.022em] mt-6 mb-6 reveal delay-75">
					Cinematic quality, <em class="italic text-[#d6c89f]">built for real estate.</em>
				</h2>
				<p class="text-paper-dim text-[var(--text-sm)] leading-relaxed max-w-[46ch] reveal delay-150">
					Designed for fast-moving listings without sacrificing atmosphere, composition, or visual quality. We work around your timeline — not ours.
				</p>
			</div>

			<!-- Tier callout -->
			<div class="grid grid-cols-1 md:grid-cols-2 border border-rule-strong mb-16 md:mb-[72px] reveal delay-150">
				<div class="px-8 py-7 md:border-r border-rule-strong">
					<div class="font-mono text-[var(--text-xs)] tracking-[0.18em] uppercase text-accent mb-3">Standard · 24–48 hrs</div>
					<p class="text-[var(--text-sm)] text-paper-dim leading-relaxed m-0">Photos, drone footage, social edits, and property videos. Fast turnaround for active listings and launch timelines.</p>
				</div>
				<div class="px-8 py-7 border-t md:border-t-0 border-rule-strong">
					<div class="font-mono text-[var(--text-xs)] tracking-[0.18em] uppercase text-paper-mute mb-3">Premium · Extended timeline</div>
					<p class="text-[var(--text-sm)] text-paper-dim leading-relaxed m-0">Multi-day ranch productions, cinematic films, and complex color work. Scoped and scheduled per project.</p>
				</div>
			</div>

			<div class="flex flex-col">
				{[
					{
						n: 'i.',
						title: 'Project <em class="italic text-[#d6c89f]">planning</em>',
						day: '24–48 hours',
						desc: 'We learn the property, discuss goals, coordinate timing, and schedule around weather and lighting conditions.'
					},
					{
						n: 'ii.',
						title: 'Production <em class="italic text-[#d6c89f]">day</em>',
						day: 'On location',
						desc: 'Aerial and ground footage captured in a unified shoot — cinematic movement, natural light, and location-aware planning.'
					},
					{
						n: 'iii.',
						title: 'Edit & <em class="italic text-[#d6c89f]">color</em>',
						day: '1–3 business days',
						desc: 'Footage is edited, color graded, and optimized for listing platforms, social media, and cinematic presentation.'
					},
					{
						n: 'iv.',
						title: 'Delivery & <em class="italic text-[#d6c89f]">launch</em>',
						day: 'Digital delivery',
						desc: 'Final assets delivered in web, social, and high-resolution formats — ready for MLS, marketing launches, and active listings.'
					}
				].map((step) => (
					<div class="reveal grid grid-cols-1 md:grid-cols-[120px_1.4fr_2fr] gap-6 md:gap-[60px] py-13.5 border-t border-rule-strong items-start last:border-b last:border-rule-strong">
						<div class="serif italic text-[var(--text-4xl)] text-accent leading-none tabular-nums">{step.n}</div>
						<div>
							<h4 class="serif text-[var(--text-3xl)] leading-[1.05] tracking-[-0.018em] text-paper m-0" set:html={step.title} />
							<div class="mt-4.5 font-mono text-[var(--text-xs)] tracking-[0.14em] uppercase text-paper-mute">{step.day}</div>
						</div>
						<p class="text-paper-dim text-[var(--text-sm)] leading-relaxed m-0 max-w-[44ch]">{step.desc}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<FAQ />

	<section id="inquire" class="relative page-px py-30 md:py-[200px] md:pb-[180px] overflow-hidden bg-black">
		<div 
			class="absolute inset-0 bg-cover bg-center opacity-28 cinematic-grade"
			style="background-image: url('https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=2400&q=80')"
		/>
		<div class="absolute inset-0 bg-gradient-to-b from-ink/55 to-ink/85" />
		
		<div class="relative z-10 max-w-[1280px] mx-auto">
			<div class="text-center mb-16 md:mb-24">
				<span class="font-mono text-[var(--text-xs)] tracking-[0.18em] uppercase text-paper-dim flex items-center justify-center gap-3 reveal">
					<span class="w-1.5 h-1.5 rounded-full bg-accent" />
					Accepting productions · June 2026 · 2 slots remaining
				</span>
				<h2 class="serif text-[var(--text-xl)] md:text-[var(--text-display)] leading-[0.96] tracking-[-0.028em] mt-7.5 mb-12.5 text-paper text-balance reveal delay-75">
					Showcase your <em class="italic text-[#e8dcc2]">property.</em>
				</h2>
				<p class="max-w-[54ch] mx-auto text-[var(--text-base)] leading-relaxed text-paper-2 reveal delay-150">
					We are currently accepting new productions across Wyoming. Whether it's a Casper commercial asset, a Laramie estate, or a ranch-scale project, we would like to hear from you.
				</p>
			</div>

			<div class="reveal delay-225">
				<div class="flex flex-wrap justify-center gap-x-12 gap-y-6 mb-20 py-8 border-y border-rule-strong max-w-[1000px] mx-auto">
					{[
						'FAA Part 107 Certified',
						'Fully Insured & Bonded',
						'Statewide Wyoming Ops',
						'Casper & Laramie Based',
						'24-48hr Media Delivery'
					].map(trust => (
						<span class="sans text-[var(--text-xs)] tracking-plate text-paper-mute uppercase whitespace-nowrap">{trust}</span>
					))}
				</div>
				<InquiryForm client:visible />
				
				<div class="mt-20 flex flex-wrap justify-center gap-x-10 gap-y-4 reveal delay-300">
					<a href="#" class="text-[var(--text-xs)] tracking-plate uppercase text-paper-mute hover:text-paper transition-colors border-b border-transparent hover:border-paper-mute pb-1">Download Services PDF</a>
					<a href="#process" class="text-[var(--text-xs)] tracking-plate uppercase text-paper-mute hover:text-paper transition-colors border-b border-transparent hover:border-paper-mute pb-1">View Workflow</a>
					<a href="#capabilities" class="text-[var(--text-xs)] tracking-plate uppercase text-paper-mute hover:text-paper transition-colors border-b border-transparent hover:border-paper-mute pb-1">Equipment & Compliance</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	const observerOptions = {
		root: null,
		rootMargin: '0px 0px -10% 0px',
		threshold: 0.08
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('reveal-in');
				observer.unobserve(entry.target);
			}
		});
	}, observerOptions);

	document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style>
	.reveal {
		opacity: 0;
		transform: translateY(28px);
		transition: opacity 1.1s var(--ease-soft), transform 1.1s var(--ease-soft);
	}

	.reveal-in {
		opacity: 1;
		transform: translateY(0);
	}
</style>