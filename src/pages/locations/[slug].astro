---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { client } from '../../lib/sanity';
import { PortableText } from '@portabletext/react';

export async function getStaticPaths() {
  return [
    { params: { slug: 'jackson-hole' } },
    { params: { slug: 'sheridan' } },
    { params: { slug: 'cody' } },
    { params: { slug: 'casper' } },
    { params: { slug: 'laramie' } },
  ];
}

const { slug } = Astro.params;

// Deepened Location Data for SEO/AEO
const locationData: Record<string, any> = {
  'jackson-hole': {
    city: 'Jackson Hole',
    heroHeadline: 'Cinematic Aerial for Jackson Hole\'s Alpine Estates.',
    terrain: 'High-altitude alpine, Snake River oxbows, and the jagged verticality of the Teton Range.',
    notes: 'Jackson operations require strict adherence to Grand Teton National Park boundaries and wildlife migration corridors. We specialize in dawn inversions and capturing the specific "alpine glow" that defines the valley\'s first light.',
    expertise: 'Winter production down to -20°F, wildlife-aware flight protocols, and ranch-scale coverage.',
    coordinates: { lat: 43.4799, lng: -110.7624 }
  },
  'casper': {
    city: 'Casper',
    heroHeadline: 'Commercial & Residential Cinematography for Central Wyoming.',
    terrain: 'High plains, river valley, and the iconic Casper Mountain interface.',
    notes: 'Our Casper hub serves as the operational center for Central Wyoming. We specialize in documenting commercial assets, industrial developments, and residential expansions across the region.',
    expertise: 'High-wind stabilization, industrial site documentation, and residential property storytelling.',
    coordinates: { lat: 42.8501, lng: -106.3252 }
  },
  'laramie': {
    city: 'Laramie',
    heroHeadline: 'High-Plains Media for Laramie\'s Architectural Assets.',
    terrain: 'High-altitude plateau, granite outcroppings, and the Snowy Range interface.',
    notes: 'Based in Laramie, we understand the specific light and weather patterns of the southern plains. We provide cinematic coverage for both university-linked assets and expansive high-country estates.',
    expertise: 'High-altitude performance, architectural motion studies, and Snowy Range regional coverage.',
    coordinates: { lat: 41.3114, lng: -105.5911 }
  },
  'sheridan': {
    city: 'Sheridan',
    heroHeadline: 'Ranch-Scale Cinematography for the Bighorn Foothills.',
    terrain: 'Rolling grasslands, high-country plateaus, and the eastern face of the Bighorn Mountains.',
    notes: 'Sheridan productions focus on the scale of the working West. We track the evening gather across thousands of acres, utilizing long-lens orbits to maintain silence and respect the livestock.',
    expertise: 'Long-range ranch documentation, cattle-aware flight paths, and big-sky lighting studies.',
    coordinates: { lat: 44.7972, lng: -106.9561 }
  },
  'cody': {
    city: 'Cody',
    heroHeadline: 'Desert Light and River Canyons: Cody Aerial Media.',
    terrain: 'High plains, dramatic river canyons, and the rugged Shoshone National Forest interface.',
    notes: 'Cody presents unique thermal challenges and high-wind conditions. Our pilots are trained for the aggressive canyon winds of the Shoshone, capturing the hard desert light that creates the region\'s iconic high-contrast landscapes.',
    expertise: 'High-wind stabilization, canyon flight plans, and thermal management for summer productions.',
    coordinates: { lat: 44.5263, lng: -109.0565 }
  }
};

const location = locationData[slug || 'jackson-hole'] || locationData['jackson-hole'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": `SKYWYO - ${location.city} Aerial Cinematography`,
  "description": `Professional drone cinematography and media production for ${location.city}'s ranches and luxury estates.`,
  "url": `https://skywyo.com/locations/${slug}`,
  "telephone": "+1 307 555 0184",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": location.city,
    "addressRegion": "WY",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": location.coordinates.lat,
    "longitude": location.coordinates.lng
  },
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": location.city
  },
  "knowsAbout": ["Aerial Cinematography", "Ranch Photography", "Luxury Real Estate Media", "Wyoming Landscapes"]
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Does SKYWYO operate in ${location.city} during winter?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Yes, our studio specializes in cold-weather operations across ${location.city}, with equipment rated for temperatures down to -20°F.`
      }
    },
    {
      "@type": "Question",
      "name": "Are you FAA Part 107 certified?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All SKYWYO pilots are FAA Part 107 certified and carry $5M in specialized aviation liability insurance."
      }
    }
  ]
};
---

<BaseLayout title={`${location.city} | SKYWYO`} description={location.heroHeadline}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  
  <section class="relative h-[85vh] w-full flex items-center justify-center overflow-hidden bg-black">
    <div 
      class="absolute inset-0 bg-cover bg-center cinematic-grade opacity-60"
      style={`background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=2600&q=85')`}
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-transparent to-black/70" />
    
    <div class="relative z-10 px-14 text-center max-w-[1200px] mx-auto">
      <span class="sans text-[11px] tracking-[0.32em] uppercase text-white/70 mb-8 block reveal">
        Regional Operations Hub — {location.city}
      </span>
      <h1 class="serif text-[clamp(48px,8vw,120px)] leading-[0.96] tracking-[-0.028em] text-white text-balance reveal delay-75">
        {location.heroHeadline}
      </h1>
      <p class="mt-10 text-white/60 text-[18px] max-w-[40ch] mx-auto reveal delay-150">
        Specialized aerial media for Wyoming's most significant land and architectural assets.
      </p>
    </div>
  </section>

  <section class="px-14 py-30 md:py-50 bg-ink">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-20 md:gap-32">
      <div class="reveal">
        <h2 class="serif text-[42px] leading-tight mb-8">Production Notes</h2>
        <p class="text-paper-dim text-[18px] leading-relaxed mb-8">
          {location.notes}
        </p>
        <div class="pt-8 border-t border-rule">
          <h4 class="sans text-[11px] text-paper-mute mb-4 uppercase">Terrain & Environment</h4>
          <p class="text-paper-dim text-[15px]">{location.terrain}</p>
        </div>
      </div>
      
      <div class="reveal delay-100">
        <h2 class="serif text-[42px] leading-tight mb-8">Regional Expertise</h2>
        <p class="text-paper-dim text-[18px] leading-relaxed mb-8">
          {location.expertise}
        </p>
        <div class="pt-8 border-t border-rule">
          <h4 class="sans text-[11px] text-paper-mute mb-4 uppercase">Service Specialization</h4>
          <ul class="list-none p-0 m-0 space-y-3">
            <li class="text-paper-dim text-[15px] flex items-center gap-3">
              <span class="w-1 h-1 rounded-full bg-accent" />
              Cinematic Ranch Documentation
            </li>
            <li class="text-paper-dim text-[15px] flex items-center gap-3">
              <span class="w-1 h-1 rounded-full bg-accent" />
              Architectural Motion Studies
            </li>
            <li class="text-paper-dim text-[15px] flex items-center gap-3">
              <span class="w-1 h-1 rounded-full bg-accent" />
              Wildlife-Aware Conservation Media
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="px-14 py-30 border-t border-rule bg-ink-2">
    <div class="max-w-[1400px] mx-auto flex flex-col md:flex-row justify-between gap-12 text-paper-dim">
      <div>
        <h5 class="text-paper text-[11px] font-medium tracking-plate uppercase mb-4.5">Local Hub</h5>
        <p class="text-[15px]">Regional Operations Center<br />{location.city}, WY 82001</p>
      </div>
      <div>
        <h5 class="text-paper text-[11px] font-medium tracking-plate uppercase mb-4.5">Operational Status</h5>
        <p class="text-[15px] flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse" />
          Active for 2026 Season
        </p>
      </div>
      <div>
        <h5 class="text-paper text-[11px] font-medium tracking-plate uppercase mb-4.5">Coordinates</h5>
        <p class="text-[15px] tabular-nums">{location.coordinates.lat.toFixed(4)}° N, {Math.abs(location.coordinates.lng).toFixed(4)}° W</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
	const observerOptions = {
		root: null,
		rootMargin: '0px 0px -10% 0px',
		threshold: 0.08
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('reveal-in');
				observer.unobserve(entry.target);
			}
		});
	}, observerOptions);

	document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style>
	.reveal {
		opacity: 0;
		transform: translateY(28px);
		transition: opacity 1.1s var(--ease-soft), transform 1.1s var(--ease-soft);
	}

	.reveal-in {
		opacity: 1;
		transform: translateY(0);
	}
</style>
